# Conexão com o banco de dados PostgreSQL
POSTGRES_CONNECTION=Host=;Port=5432;Database=;Username=;Password=;

# JWT
JWT__SECRET=
JWT__ISSUER=coeur-api
JWT__AUDIENCE=coeur-api
JWT__EXPIRATIONHOURS=24

# Hosts permitidos (separar múltiplos por ponto-e-vírgula)
ALLOWED_HOSTS=seudominio.com

# Origens do front-end liberadas no CORS (separar múltiplas por ponto-e-vírgula)
CORS_ALLOWED_ORIGINS=https://coeur.app.br

# Roda "dotnet ef database update" automaticamente no startup. Desligue (false) se
# migration passar a rodar como step separado do deploy (ex. múltiplas réplicas).
DATABASE_AUTO_MIGRATE=true
